# Copy to .env and fill in. SEC requires a declared User-Agent with contact info.
SEC_USER_AGENT="equity-filing-delta your-email@example.com"

# Optional price source (free tier). Stooq needs no key; Tiingo does.
TIINGO_API_KEY=""

# Grounded narrator (docs page + scripts/narrate_event.py).
# GLM 5.2 via NVIDIA's OpenAI-compatible endpoint — free key at build.nvidia.com.
NVIDIA_API_KEY=""

# Optional: the diff-grounded risk-factor classifier (scripts/classify_sample.py)
# still uses Anthropic structured outputs. Leave blank unless you run it.
ANTHROPIC_API_KEY=""
